    "fig = go.Figure()\n",
    "\n",
    "for bearing in rms_all:\n",
    "    rolling = pd.Series(rms_all[bearing]).rolling(window=20).mean()\n",
    "    \n",
    "    fig.add_trace(go.Scatter(x=timestamps, y=rolling, name=bearing,\n",
    "                             line=dict(color=colors[bearing])))\n",
    "    \n",
    "    fig.add_hline(y=results[bearing][\"threshold\"],\n",
    "                  line_dash=\"dash\",\n",
    "                  line_color=colors[bearing],\n",
    "                  annotation_text=f\"{bearing} threshold\",\n",
    "                  annotation_position=\"right\")\n",
    "\n",
    "fig.update_layout(title=\"All 4 Bearings - RMS with Personal Thresholds\",\n",
    "                  xaxis_title=\"Date\",\n",
    "                  yaxis_title=\"RMS Vibration (g)\")\n",
    "fig.show()"
