    "from scipy.fft import fft, fftfreq\n",
    "import numpy as np\n",
    "\n",
    "# Load first snapshot (healthy) and last snapshot (failure)\n",
    "df_healthy = pd.read_csv(os.path.join(folder, files[0]), sep=\"\\t\", header=None,\n",
    "                         names=[\"Bearing1\",\"Bearing2\",\"Bearing3\",\"Bearing4\"])\n",
    "\n",
    "df_failed = pd.read_csv(os.path.join(folder, files[-1]), sep=\"\\t\", header=None,\n",
    "                        names=[\"Bearing1\",\"Bearing2\",\"Bearing3\",\"Bearing4\"])\n",
    "\n",
    "# Sample rate for this dataset is 20,480 Hz\n",
    "sample_rate = 20480\n",
    "\n",
    "# Calculate FFT for both\n",
    "fft_healthy = np.abs(fft(df_healthy[\"Bearing3\"]))\n",
    "fft_failed = np.abs(fft(df_failed[\"Bearing3\"]))\n",
    "\n",
    "# Frequency axis\n",
    "freqs = fftfreq(len(df_healthy), 1/sample_rate)\n",
    "\n",
    "# Only plot positive frequencies\n",
    "mask = freqs > 0\n",
    "\n",
    "fig = go.Figure()\n",
    "fig.add_trace(go.Scatter(x=freqs[mask], y=fft_healthy[mask], name=\"Healthy\"))\n",
    "fig.add_trace(go.Scatter(x=freqs[mask], y=fft_failed[mask], name=\"Failed\"))\n",
    "\n",
    "fig.update_layout(title=\"Bearing 3 - FFT Healthy vs Failed\",\n",
    "                  xaxis_title=\"Frequency (Hz)\",\n",
    "                  yaxis_title=\"Amplitude\")\n",
    "fig.show()"
   ]
