    "from plotly.subplots import make_subplots\n",
    "\n",
    "fig = make_subplots(rows=2, cols=1, \n",
    "                    subplot_titles=(\"RMS - All 4 Bearings\", \"Kurtosis - All 4 Bearings\"))\n",
    "\n",
    "for bearing in rms_all:\n",
    "    rolling_rms = pd.Series(rms_all[bearing]).rolling(window=20).mean()\n",
    "    rolling_kurt = pd.Series(kurt_all[bearing]).rolling(window=20).mean()\n",
    "    \n",
    "    fig.add_trace(go.Scatter(y=rolling_rms, name=bearing), row=1, col=1)\n",
    "    fig.add_trace(go.Scatter(y=rolling_kurt, name=bearing, showlegend=False), row=2, col=1)\n",
    "\n",
    "fig.add_hline(y=0.1, line_dash=\"dash\", line_color=\"red\", row=1, col=1)\n",
    "fig.add_hline(y=3.0, line_dash=\"dash\", line_color=\"red\", row=2, col=1)\n",
    "\n",
    "fig.update_layout(height=700, title=\"RMS vs Kurtosis - Run to Failure\")\n",
    "fig.show()"
   ]
  },
