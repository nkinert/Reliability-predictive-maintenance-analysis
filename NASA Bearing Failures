    "import plotly.graph_objects as go\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "for bearing in rms_all:\n",
    "    rolling = pd.Series(rms_all[bearing]).rolling(window=20).mean()\n",
    "    fig.add_trace(go.Scatter(y=rolling, name=bearing))\n",
    "\n",
    "# Alert threshold line\n",
    "fig.add_hline(y=0.05, line_dash=\"dash\", line_color=\"red\", \n",
    "              annotation_text=\"Alert Threshold\")\n",
    "\n",
    "fig.update_layout(title=\"All 4 Bearings - RMS Run to Failure\",\n",
    "                  xaxis_title=\"Snapshot #\",\n",
    "                  yaxis_title=\"RMS Vibration (g)\")\n",
    "fig.show()"
   ]
