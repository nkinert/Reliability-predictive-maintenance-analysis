    "kurt_all = {\"Bearing1\": [], \"Bearing2\": [], \"Bearing3\": [], \"Bearing4\": []}\n",
    "\n",
    "for file in files:\n",
    "    filepath = os.path.join(folder, file)\n",
    "    df = pd.read_csv(filepath, sep=\"\\t\", header=None,\n",
    "                     names=[\"Bearing1\",\"Bearing2\",\"Bearing3\",\"Bearing4\"])\n",
    "    for bearing in kurt_all:\n",
    "        kurt_all[bearing].append(df[bearing].kurtosis())\n",
    "\n",
    "print(\"Done! Kurtosis calculated for all 4 bearings\")"
   ]
